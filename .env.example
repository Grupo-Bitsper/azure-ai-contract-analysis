# ============================================================================
# Azure OpenAI Configuration
# ============================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Embeddings
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_API_VERSION=2024-12-01-preview

# ============================================================================
# Azure AI Search Configuration
# ============================================================================
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX=contratos-rocka-index

# ============================================================================
# Azure Document Intelligence (OCR)
# ============================================================================
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intel.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your-doc-intel-key

# ============================================================================
# SharePoint Configuration (Opcional - para sync automático)
# ============================================================================
# URL del sitio de SharePoint donde están los contratos
SHAREPOINT_SITE_URL=https://gruporocka.sharepoint.com/sites/contratos

# Credenciales de la App registrada en Azure AD
# (Ver: https://learn.microsoft.com/sharepoint/dev/solution-guidance/security-apponly-azuread)
SHAREPOINT_CLIENT_ID=your-app-id
SHAREPOINT_CLIENT_SECRET=your-app-secret

# Nombre de la biblioteca de documentos en SharePoint
SHAREPOINT_LIBRARY=Contratos

# ============================================================================
# Azure AD (Para obtener grupos de usuarios)
# ============================================================================
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ============================================================================
# Azure Foundry (Agent Service)
# ============================================================================
PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
PROJECT_CONNECTION_STRING=https://your-resource.services.ai.azure.com/api/projects/your-project
RESOURCE_NAME=your-resource-name
PROJECT_NAME=your-project-name

# ============================================================================
# Configuración del Proyecto
# ============================================================================
# Directorio donde están los PDFs locales (para testing)
CONTRACTS_DIR=/ruta/a/contratos/locales

# Modo de chunking: "sentence" o "semantic"
CHUNKING_MODE=semantic
