# =============================================================================
# ROCA Copilot — .env.example
# =============================================================================
# Variables de entorno de referencia para desarrollo local de ROCA Copilot.
# Copiar este archivo a `.env` y rellenar con los valores reales antes de correr
# cualquier script.
#
# .env real NO se commitea — ya está en .gitignore.
#
# Estado al 2026-04-15 (cierre de Fase 3). Actualizar cuando se creen recursos
# de Fases 4–6 (índice AI Search, Logic App, Foundry agent wiring, etc.).
# =============================================================================


# -----------------------------------------------------------------------------
# Tenant y suscripción (Fase 1)
# -----------------------------------------------------------------------------
# Tenant de ROCA TEAM (Entra ID) — `az account show --query tenantId`
AZURE_TENANT_ID=9015a126-356b-4c63-9d1f-d2138ca83176

# Suscripción FES Azure Plan donde vive ROCA Copilot
# `az account show --query id`
AZURE_SUBSCRIPTION_ID=fea67fdf-9603-4c86-a590-cd12390b7efd

# Resource group de producción — protegido con CanNotDelete lock
AZURE_RESOURCE_GROUP=rg-roca-copilot-prod
AZURE_LOCATION=eastus2


# -----------------------------------------------------------------------------
# SharePoint sync robot (Fase 2) — App Registration con Sites.Selected
# -----------------------------------------------------------------------------
# App Registration `roca-copilot-sync-agent` (authentication con client secret,
# posiblemente migrado a Federated Credentials en Fase 5 — revisar plan).
SYNC_AGENT_APP_ID=18884cef-ace3-4899-9a54-be7eb66587b7
SYNC_AGENT_SP_ID=c14b0ac5-1f88-4eaf-860a-c96354267d86

# Client secret NO se pone aquí — leer del Key Vault.
# Referencia: https://kv-roca-copilot-prod.vault.azure.net/secrets/roca-copilot-sync-agent-secret
# Para test local: `az keyvault secret show --vault-name kv-roca-copilot-prod --name roca-copilot-sync-agent-secret --query value -o tsv`
SYNC_AGENT_CLIENT_SECRET=__leer_de_key_vault__


# -----------------------------------------------------------------------------
# Key Vault (Fase 2)
# -----------------------------------------------------------------------------
# RBAC mode, purge protection ON, 7-day retention
KEY_VAULT_NAME=kv-roca-copilot-prod
KEY_VAULT_URI=https://kv-roca-copilot-prod.vault.azure.net/
KEY_VAULT_SECRET_SYNC_AGENT=roca-copilot-sync-agent-secret


# -----------------------------------------------------------------------------
# SharePoint sites autorizados (Fase 2)
# -----------------------------------------------------------------------------
# Sites donde el sync robot tiene Sites.Selected grant (Write).
SHAREPOINT_HOST=rocadesarrollos1.sharepoint.com
SHAREPOINT_SITE_1_NAME=ROCA-IAInmuebles
SHAREPOINT_SITE_2_NAME=ROCAIA-INMUEBLESV2


# -----------------------------------------------------------------------------
# Azure AI Foundry (Fase 2 — creado fuera del RG de ROCA)
# -----------------------------------------------------------------------------
# Foundry project `rocadesarrollo` vive bajo el AIServices account
# `rocadesarrollo-resource` en `rg-admin.copilot-9203`. El agente y los deployments
# OpenAI viven ahí. ROCA Copilot consume ese account pero NO lo administra.
FOUNDRY_PROJECT_NAME=rocadesarrollo
FOUNDRY_AISERVICES_ACCOUNT=rocadesarrollo-resource
FOUNDRY_AISERVICES_RG=rg-admin.copilot-9203
# ⚠ CORREGIDO 2026-04-15 smoke test: el MI real que el Foundry agent usa para autenticarse
# contra recursos externos es el SystemAssigned MI del AIServices account PADRE
# (`rocadesarrollo-resource`), NO el del project child. El valor anterior `8117b1a5-...` era
# un MI distinto (posiblemente legacy o del project, pero NO el que el playground usa).
FOUNDRY_AISERVICES_MI_PRINCIPAL_ID=0a7473b6-0c5e-46dd-bc5c-87a6b1dd7b96
# Legacy/secundario — se le mantienen role assignments como backup pero NO es el usado por default
FOUNDRY_PROJECT_MI_PRINCIPAL_ID_LEGACY=8117b1a5-5225-4d9e-9071-ee9aa90b7eb0
FOUNDRY_PROJECT_ENDPOINT=https://rocadesarrollo-resource.services.ai.azure.com/api/projects/rocadesarrollo

# ⚠ OBSOLETO 2026-04-15: `asst_I1unL8WG7qDjaz8nNJ0PCkkw` era de la API legacy OpenAI Assistants (classic),
# NO existe en Foundry v2. El agente placeholder `Agent932` fue borrado por el usuario 2026-04-15.
# El agente smoke test actual es `roca-copilot-smoke` (gpt-4o-mini + AI Search tool → roca-contracts-smoke).
# FOUNDRY_EXISTING_AGENT_ID=asst_I1unL8WG7qDjaz8nNJ0PCkkw
FOUNDRY_SMOKE_AGENT_ID=roca-copilot-smoke
FOUNDRY_SMOKE_AGENT_VERSION=1

# Smoke test resources (borrar al terminar Fase 4A iteración)
AZURE_SEARCH_SMOKE_INDEX=roca-contracts-smoke
AZURE_SEARCH_SMOKE_QUERYKEY_SECRET=roca-search-smoke-querykey
FOUNDRY_SMOKE_CONNECTION_NAME=roca-search-smoke


# -----------------------------------------------------------------------------
# Azure OpenAI deployments (Fase 3) — dentro de rocadesarrollo-resource
# -----------------------------------------------------------------------------
# **DOS modelos chat desplegados 2026-04-15**:
# 1. `gpt-5-mini` — reasoning model para DISCOVERY/EXTRACCIÓN (Fase 4A, Fase 5 ingesta).
#    NO compatible con el tool nativo "Azure AI Search" de Foundry agents (GPT-5 family limitation).
# 2. `gpt-4o-mini` — modelo rápido/barato para AGENTES con AI Search tool (Foundry-compatible).
#    Desplegado para smoke test y probablemente Fase 6. Pay-per-use, $0 recurrente.
# NO usar gpt-4o (el grande, fue eliminado 2026-04-15 por costo).
AZURE_OPENAI_ENDPOINT=https://rocadesarrollo-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21

# Discovery / extracción pipeline (Fase 4A + Fase 5 ingesta)
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_CHAT_MODEL=gpt-5-mini
AZURE_OPENAI_CHAT_MODEL_VERSION=2025-08-07

# Agente RAG (Fase 6 playground + producción probable)
AZURE_OPENAI_AGENT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_AGENT_MODEL=gpt-4o-mini
AZURE_OPENAI_AGENT_MODEL_VERSION=2024-07-18

# Embeddings (ambos fases)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536

# API key NO se pone aquí — usar Managed Identity o AAD token.
# Para pruebas locales: `az cognitiveservices account keys list --name rocadesarrollo-resource --resource-group rg-admin.copilot-9203 --query key1 -o tsv`
AZURE_OPENAI_API_KEY=__usar_managed_identity_o_aad__


# -----------------------------------------------------------------------------
# Azure AI Search (Fase 3)
# -----------------------------------------------------------------------------
# Creado en eastus (no eastus2) porque eastus2 estaba out-of-capacity para Basic
# el 2026-04-15. Mismo RG, distinta región — cross-region overhead irrelevante.
AZURE_SEARCH_SERVICE_NAME=srch-roca-copilot-prod
AZURE_SEARCH_ENDPOINT=https://srch-roca-copilot-prod.search.windows.net
AZURE_SEARCH_LOCATION=eastus
AZURE_SEARCH_SKU=basic
AZURE_SEARCH_MI_PRINCIPAL_ID=c9181743-c085-4885-8ff7-81392e0d2d5a
AZURE_SEARCH_SEMANTIC_CONFIG=default-semantic-config

# Nombre del índice — se crea en Fase 4B después del discovery de schema.
AZURE_SEARCH_INDEX_NAME=roca-contracts-v1

# Admin key NO se pone aquí — usar Managed Identity (RBAC).
# Para pruebas locales: `az search admin-key show --service-name srch-roca-copilot-prod --resource-group rg-roca-copilot-prod --query primaryKey -o tsv`
AZURE_SEARCH_ADMIN_KEY=__usar_managed_identity__


# -----------------------------------------------------------------------------
# Azure Blob Storage (Fase 3) — OCR raw + artifacts
# -----------------------------------------------------------------------------
# Container `ocr-raw` guarda el JSON crudo de Document Intelligence por documento
# para permitir re-indexación sin pagar OCR dos veces.
AZURE_STORAGE_ACCOUNT=strocacopilotprod
AZURE_STORAGE_BLOB_ENDPOINT=https://strocacopilotprod.blob.core.windows.net/
AZURE_STORAGE_CONTAINER_OCR_RAW=ocr-raw
AZURE_STORAGE_MI_PRINCIPAL_ID=c39ba7f1-1898-4c15-bded-9bf4d2bc06eb

# Connection string NO se pone aquí — usar Managed Identity (RBAC).
# Para pruebas locales con AAD: `az storage blob list --account-name strocacopilotprod --container-name ocr-raw --auth-mode login`
AZURE_STORAGE_CONNECTION_STRING=__usar_managed_identity__


# -----------------------------------------------------------------------------
# Application Insights + Log Analytics (Fase 3)
# -----------------------------------------------------------------------------
# Workspace-based Application Insights para observabilidad del Logic App y del
# agente Foundry.
APPINSIGHTS_NAME=appi-roca-copilot-prod
APPINSIGHTS_APP_ID=732d89e9-8f2d-4eae-a9c1-cd31fb66c9c0
APPINSIGHTS_INSTRUMENTATION_KEY=2a7c7622-1eea-476e-86ca-5c9d08e86626
APPINSIGHTS_CONNECTION_STRING=__obtener_del_portal_o_via_az__
LOG_ANALYTICS_WORKSPACE=log-roca-copilot-prod


# -----------------------------------------------------------------------------
# Document Intelligence (opcional — se decide en Fase 4A)
# -----------------------------------------------------------------------------
# El account rocadesarrollo-resource es AIServices multiservicio, así que expone
# también el endpoint de Document Intelligence sin necesidad de crear un recurso
# separado. Mismo endpoint y mismas credenciales.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://rocadesarrollo-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-07-31


# -----------------------------------------------------------------------------
# Logic App Standard (Fase 5 — NO existe todavía)
# -----------------------------------------------------------------------------
# Variables reservadas para cuando se cree el Logic App de sync SharePoint→Search.
# Descomentarse en Fase 5.
# LOGIC_APP_NAME=logic-roca-copilot-sync
# LOGIC_APP_MI_PRINCIPAL_ID=__asignar_en_fase_5__


# -----------------------------------------------------------------------------
# Budget / cost alerts (Fase 3)
# -----------------------------------------------------------------------------
BUDGET_NAME=budget-roca-copilot-prod
BUDGET_AMOUNT_USD=300
ACTION_GROUP_NAME=ag-roca-copilot-prod
ALERT_EMAIL=admin.copilot@rocadesarrollos.com
